{
  "name": "ichiflow",
  "version": "0.0.0",
  "private": true,
  "description": "AI-native enterprise workflow development framework",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "schema:build": "pnpm --filter @ichiflow/schemas build",
    "schema:drift": "pnpm --filter @ichiflow/schemas drift",
    "contract:diff": "node schemas/scripts/contract-diff.mjs",
    "contract:accept": "node schemas/scripts/contract-accept.mjs",
    "license:check": "node tools/license-check/index.mjs",
    "codegen:ts": "pnpm --filter @ichiflow/contracts-ts generate",
    "codegen:drift": "pnpm --filter @ichiflow/contracts-ts drift",
    "spike:jvm": "cd core && ./gradlew -q runSpike",
    "vectors:jvm": "cd core && ./gradlew -q runContractVectors",
    "decision:jvm": "cd core && ./gradlew -q runDecisionSpike",
    "decision-tck:jvm": "cd core && ./gradlew -q runDecisionTck",
    "projection:jvm": "cd core && ./gradlew -q runProjectionCoverage",
    "trace:jvm": "cd core && ./gradlew -q runDecisionTrace",
    "scenario:jvm": "cd core && ./gradlew -q runScenarioCoverage",
    "feel:jvm": "cd core && ./gradlew -q runFeelVectors",
    "entity:jvm": "cd core && ./gradlew -q runEntityStore",
    "authz:jvm": "cd core && ./gradlew -q runAuthz",
    "ui:generate": "pnpm --filter @ichiflow/uischema build && pnpm --filter @ichiflow/uischema exec node dist/generate.js",
    "ui:preview": "pnpm --filter @ichiflow/uischema build && pnpm --filter @ichiflow/uischema preview",
    "api:contract": "pnpm --filter @ichiflow/api build && pnpm --filter @ichiflow/api contract",
    "interpreter:spike": "pnpm --filter @ichiflow/flow build && pnpm --filter @ichiflow/flow spike",
    "flow:conformance": "pnpm --filter @ichiflow/flow build && pnpm --filter @ichiflow/flow conformance",
    "decisionrecord:assemble": "pnpm --filter @ichiflow/flow build && pnpm --filter @ichiflow/flow decisionrecord",
    "portal:preview": "pnpm --filter @ichiflow/flow build && pnpm --filter @ichiflow/portal build && pnpm --filter @ichiflow/portal preview",
    "adapters:preview": "pnpm --filter @ichiflow/adapters build && pnpm --filter @ichiflow/adapters preview",
    "issuance:preview": "pnpm --filter @ichiflow/issuance build && pnpm --filter @ichiflow/issuance preview",
    "quality:jvm": "cd core && ./gradlew -q detekt test",
    "verify": "node packages/cli/dist/cli.js verify"
  },
  "devDependencies": {
    "prettier": "3.3.3"
  }
}

{
  "name": "@ichiflow/contracts-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Generated TypeScript contract types from the OpenAPI 3.1 emit (hey-api). Contract of record — regenerate, never hand-edit.",
  "scripts": {
    "generate": "openapi-ts",
    "drift": "node ./scripts/drift-check.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"src/gen/**\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "9.15.0",
    "@hey-api/openapi-ts": "0.80.0",
    "@types/node": "20.17.6",
    "eslint": "9.15.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.18.0",
    "vitest": "2.1.5"
  }
}

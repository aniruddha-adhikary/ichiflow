{
  "engine": "drools",
  "engineVersion": "10.2.0",
  "vectors": [
    {
      "id": "sort-ascending",
      "expr": "sort([3, 1, 2], function(a, b) a < b)",
      "expect": "[1, 2, 3]",
      "note": "list sort ordering is a known FEEL interchange-ambiguity spot (research 01 §7); pinned ascending."
    },
    {
      "id": "sort-descending",
      "expr": "sort([1, 3, 2], function(a, b) a > b)",
      "expect": "[3, 2, 1]",
      "note": "comparator direction is honoured deterministically."
    },
    {
      "id": "string-join-sep",
      "expr": "string join([\"a\", \"b\", \"c\"], \"-\")",
      "expect": "a-b-c",
      "note": "string join separator handling."
    },
    {
      "id": "decimal-half-even",
      "expr": "decimal(0.125, 2)",
      "expect": "0.12",
      "note": "FEEL decimal() rounds half-to-even; 0.125 -> 0.12, not 0.13."
    },
    {
      "id": "date-arithmetic",
      "expr": "date(\"2026-01-31\") + duration(\"P1D\")",
      "expect": "2026-02-01",
      "note": "date + day-duration; month boundary crossing is deterministic."
    },
    {
      "id": "mode-tie-ordering",
      "expr": "mode([1, 2, 2, 3, 3])",
      "expect": "[2, 3]",
      "note": "mode() tie-break ordering is under-specified across engines; pinned ascending."
    }
  ]
}

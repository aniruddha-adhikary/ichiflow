{
  "name": "external-task malformed (§2.8) — a schema-invalid correlated reply lands in the DLQ and surfaces on the Case, then the SLA expiry escalates: a delegation never simply hangs",
  "flow": {
    "id": "external-malformed",
    "schemaVersion": "flow/v1",
    "input": { "vars": { "applicantId": 8 } },
    "steps": [
      {
        "id": "screen",
        "type": "external-task",
        "requestRef": "adapter://vetting/credential-check-submit",
        "responseSchema": "schema://vetting/CredentialCheckResult/1",
        "in": ["applicantId"],
        "out": "verdict",
        "provider": "acme-vetting",
        "slaMs": 2592000000,
        "onTimeout": -1,
        "escalationQueue": "vetting-supervisor"
      }
    ]
  },
  "replies": [
    {
      "afterMs": 1000,
      "stepId": "screen",
      "correlationId": "conformance-external-malformed/screen",
      "messageId": "reply-1",
      "malformed": true
    }
  ],
  "expect": {
    "vars": { "applicantId": 8, "verdict": -1 },
    "steps": 1,
    "slaMs": 2592000000,
    "events": [
      "case.created",
      "external.submitted",
      "external.dlq",
      "case.flagged",
      "external.timeout",
      "external.escalated",
      "case.resolved"
    ],
    "correlations": [
      { "stepId": "screen", "correlationId": "conformance-external-malformed/screen" }
    ]
  }
}

{
  "name": "external-task submit (§2.8, doc 05 §11.1) — the request is encoded and a correlation id (case_id '/' step.id) is injected on the outbound submit; a correlated reply completes it",
  "flow": {
    "id": "external-submit",
    "schemaVersion": "flow/v1",
    "input": { "vars": { "applicantId": 3 } },
    "steps": [
      {
        "id": "screen",
        "type": "external-task",
        "requestRef": "adapter://vetting/credential-check-submit",
        "responseSchema": "schema://vetting/CredentialCheckResult/1",
        "in": ["applicantId"],
        "out": "verdict",
        "provider": "acme-vetting",
        "slaMs": 2592000000,
        "onTimeout": -1
      }
    ]
  },
  "replies": [
    {
      "afterMs": 1000,
      "stepId": "screen",
      "correlationId": "conformance-external-submit/screen",
      "messageId": "reply-1",
      "value": 7
    }
  ],
  "expect": {
    "vars": { "applicantId": 3, "verdict": 7 },
    "steps": 1,
    "slaMs": 0,
    "events": ["case.created", "external.submitted", "external.responded", "case.resolved"],
    "correlations": [{ "stepId": "screen", "correlationId": "conformance-external-submit/screen" }]
  }
}

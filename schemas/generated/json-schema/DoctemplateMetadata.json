{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "DoctemplateMetadata.json",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "version": {
            "$ref": "SemanticVersion.json"
        },
        "governanceState": {
            "type": "string",
            "const": "released"
        },
        "ownerTeam": {
            "type": "string"
        }
    },
    "required": [
        "id",
        "version",
        "governanceState",
        "ownerTeam"
    ]
}
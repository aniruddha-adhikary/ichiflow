{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "EntityAuditExpectation.json",
    "type": "object",
    "properties": {
        "operation": {
            "$ref": "EntityOp.json"
        },
        "id": {
            "type": "string"
        },
        "version": {
            "type": "integer",
            "minimum": 1,

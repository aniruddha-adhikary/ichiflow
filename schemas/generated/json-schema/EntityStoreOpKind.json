{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "EntityStoreOpKind.json",
    "anyOf": [
        {
            "type": "string",
            "const": "create"
        },
        {
            "type": "string",
            "const": "update"
        },
        {
            "type": "string",

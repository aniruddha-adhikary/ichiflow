{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "NotificationDispositionCounts.json",
    "type": "object",
    "properties": {
        "sent": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2147483647,
            "description": "Deliveries delivered exactly once by the provider driver."
        },
        "deduped": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2147483647,
            "description": "Duplicate deliveries deduped once."
        },
        "dlq": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2147483647,
            "description": "Deliveries quarantined in the DLQ after bounded attempts."
        }
    },
    "required": [
        "sent",
        "deduped",
        "dlq"
    ],
    "description": "The pinned outcome of a reliability vector — how many deliveries were sent / deduped / quarantined."
}
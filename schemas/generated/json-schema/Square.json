{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "Square.json",
    "type": "object",
    "properties": {
        "kind": {
            "type": "string",
            "const": "square"
        },
        "side": {
            "type": "number",
            "minimum": 0
        }
    },
    "required": [
        "kind",
        "side"
    ],
    "allOf": [
        {
            "$ref": "Shape.json"
        }
    ]
}
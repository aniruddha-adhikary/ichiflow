      }
    },
    {
      "id": "scalar.ratio-exclusive-min",
      "schema": "ScalarProbe.json",
      "expect": "reject",
      "instance": {
        "email": "user@example.com",
        "when": "2026-07-12T00:00:00Z",
        "rating": 3,

{
  "description": "Cross-language fidelity probe corpus (build plan 1.0). Each vector names an emitted schema (by generated filename), a JSON instance, and the expected verdict. Two independent validators — Ajv (TS) and networknt (JVM) — must BOTH match `expect` AND agree with each other on every vector. Constructs are chosen to be the ones validators most often diverge on: optional-vs-nullable, format assertion, numeric bounds/exclusivity, int32 range inside a union, and cross-file $ref resolution.",
  "vectors": [
    {
      "id": "nullability.optional-absent",
      "schema": "NullabilityProbe.json",
      "expect": "accept",
      "instance": { "required": "a", "nullable": "b" }
    },
    {
      "id": "nullability.explicit-null-ok",
      "schema": "NullabilityProbe.json",
      "expect": "accept",
      "instance": { "required": "a", "optional": "o", "nullable": null }
    },
    {
      "id": "nullability.missing-required",
      "schema": "NullabilityProbe.json",
      "expect": "reject",
      "instance": { "nullable": "b" }
    },
    {
      "id": "nullability.missing-nullable-key",
      "schema": "NullabilityProbe.json",
      "expect": "reject",
      "instance": { "required": "a" }
    },
    {
      "id": "nullability.optional-is-not-nullable",
      "schema": "NullabilityProbe.json",
      "expect": "reject",
      "instance": { "required": "a", "optional": null, "nullable": "b" }
    },
    {
      "id": "nullability.required-wrong-type",
      "schema": "NullabilityProbe.json",
      "expect": "reject",
      "instance": { "required": 5, "nullable": "b" }
    },
    {
      "id": "scalar.all-valid",
      "schema": "ScalarProbe.json",
      "expect": "accept",
      "instance": {
